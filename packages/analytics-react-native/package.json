{
  "name": "amplitude-rn-analytics",
  "version": "1.5.53",
  "description": "Storage-agnostic React Native analytics SDK for Amplitude services",
  "keywords": [
    "analytics",
    "amplitude",
    "react-native",
    "ios",
    "android"
  ],
  "author": "Joao Paulo C. Marra",
  "homepage": "https://github.com/JoaoPauloCMarra/amplitude-rn-analytics",
  "license": "MIT",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoaoPauloCMarra/amplitude-rn-analytics.git"
  },
  "scripts": {
    "build": "bob build",
    "clean": "rimraf node_modules lib coverage",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --ignore-pattern \"**/*.d.ts\" --fix",
    "fix:prettier": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" --ignore-path .prettierignore",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --ignore-pattern \"**/*.d.ts\"",
    "lint:prettier": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" --ignore-path .prettierignore",
    "test": "npm run test:web && npm run test:mobile",
    "test:web": "jest --setupFiles './test/mock/setup-web.ts'",
    "test:mobile": "jest --setupFiles './test/mock/setup-mobile.ts'",
    "typecheck": "tsc -p ./tsconfig.json",
    "prepare": "npm run version-file && npm run build",
    "version": "npm run version-file && npm run build",
    "version-file": "node -p \"'export const VERSION = \\'' + require('./package.json').version + '\\';'\" > src/version.ts",
    "typescript": "tsc --noEmit",
    "example": "npm install --prefix example",
    "pods": "cd example && pod-install --quiet"
  },
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "amplitude-react-native.podspec",
    "!android/build",
    "!ios/build",
    "!**/test"
  ],
  "bugs": {
    "url": "https://github.com/JoaoPauloCMarra/amplitude-rn-analytics/issues"
  },
  "dependencies": {
    "@amplitude/analytics-core": "2.41.5",
    "@amplitude/ua-parser-js": "^0.7.31",
    "tslib": "^2.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.0.26",
    "@types/react-native": "0.70.8",
    "@types/ua-parser-js": "^0.7.39",
    "react": "18.2.0",
    "react-native": "0.70.6",
    "react-native-builder-bob": "^0.20.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
